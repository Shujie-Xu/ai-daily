{
  "name": "ai-daily",
  "version": "0.3.0",
  "description": "Daily AI news digest — auto-fetched, rendered, pushed to GitHub Pages",
  "type": "commonjs",
  "private": true,
  "scripts": {
    "fetch": "node src/fetch/search.js",
    "fetch:rss": "node src/fetch/rss.js",
    "fetch:weak": "node src/fetch/weak-signal.js",
    "fetch:bodies": "node src/fetch/parallel.js",
    "merge": "node src/pipeline/merge.js",
    "dedup:events": "node src/pipeline/dedup-events.js",
    "record:events": "node src/pipeline/record-events.js",
    "render": "node src/render/generate.js",
    "render:push": "node src/render/generate.js --push",
    "clean:events": "node src/pipeline/clean-events.js",
    "clean:audio": "node src/pipeline/clean-audio.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "js-yaml": "^4.1.1",
    "rss-parser": "^3.13.0"
  }
}
